{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "title": {
      "type": "string"
    },
    "description": {
      "type": "string"
    },
    "image": {
      "type": "string"
    },
    "link": {
      "type": "string",
      "format": "uri"
    },
    "alt": {
      "type": "string"
    },
    "tech": {
      "type": "string"
    },
    "status": {
      "type": "string"
    },
    "category": {
      "type": "string"
    },
    "featured": {
      "default": false,
      "type": "boolean"
    },
    "order": {
      "type": "number"
    },
    "$schema": {
      "type": "string"
    }
  },
  "required": [
    "title",
    "description",
    "image",
    "link",
    "alt",
    "tech",
    "status",
    "category"
  ]
}